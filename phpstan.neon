parameters:
	level: 8

	paths:
		- src

	ignoreErrors:
		# McpToolCallGuard catches exceptions the decorated SDK handler really throws at runtime, but
		# its interface under-declares @throws, so PHPStan flags the catches (and extractGoogleError,
		# called only from one) as dead. False positives, scoped to this file.
		-
			identifier: catch.neverThrown
			path: src/McpToolCallGuard.php
		-
			identifier: method.unused
			path: src/McpToolCallGuard.php

		-	# Google's generated stub types MessagePart::getBody() as non-nullable,
			# but with format=metadata it returns null at runtime (see commit ec082e0).
			# The ?-> operator is the correct guard; removing it reintroduces a fatal Error.
			identifier: nullsafe.neverNull
			message: '#^Using nullsafe method call on non-nullable type Google\\Service\\Gmail\\MessagePartBody\. Use -> instead\.$#'
			path: src/Gmail/Manager.php
			count: 2
