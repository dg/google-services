{
	"name": "dg/google-services",
    "require": {
		"php": "8.2 - 8.5",
        "google/apiclient": "^2.18"
    },
	"require-dev": {
		"phpstan/phpstan": "^2.1@stable",
		"phpstan/extension-installer": "^1.4@stable",
		"nette/phpstan-rules": "^1.0"
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"scripts": {
		"phpstan": "phpstan analyse"
	},
	"config": {
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	}
}
